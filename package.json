{
  "name": "agent-guardrails",
  "version": "0.1.0",
  "description": "Policy engine for AI coding agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write ."
  },
  "keywords": ["agent", "guardrails", "safety", "ai"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "yaml": "^2.4.0",
    "@types/node": "^20.12.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0"
  }
}
